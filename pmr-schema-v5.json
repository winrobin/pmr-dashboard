{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PMR Investment V5 - Investment-Grade Dataset",
  "description": "审计级、可筛选、可追踪的PMR投资数据模型",
  "type": "object",
  "required": ["id","propertyName","location","createdAt","lastUpdated","dataCompletenessScore","verificationStatus","hardFailReasons","scores","nextAction"],
  "properties": {
    "id": {"type": "string","description":"内部唯一标识，如 BW-001"},
    "propertyName": {"type": "string"},
    "location": {"type": "string"},
    "createdAt": {"type":"string","format":"date-time"},
    "lastUpdated": {"type":"string","format":"date-time"},
    "dataCompletenessScore": {"type":"number","minimum":0,"maximum":100,"description":"0-100的数据完整度分数，基于关键字段计算"},
    "verificationStatus": {
      "type":"string",
      "enum":["verified","listing-only","rumour","estimated","partial"],
      "description":"整体数据可信度等级"
    },
    "verificationDetails": {
      "type":"object",
      "description":"各数据源核验情况",
      "properties":{
        "broker":{"type":"boolean","description":"是否得到经纪人书面确认"},
        "bodyCorporate":{"type":"boolean","description":"是否向Body Corporate核实"},
        "financials":{"type":"boolean","description":"是否查看过3年财报"}
      }
    },
    "hardFailReasons": {
      "type":"array",
      "items":{"type":"string"},
      "description":"直接淘汰条件（需满足时才填入）"
    },
    "agreementType": {"type":["string","null"],"enum":["caretaking","letting-only","dual","other"]},
    "agreementModule": {"type":["string","null"],"description":"如 'On-Site Manager', 'Off-Site Portfolio Manager'"},
    "contractYearsRemaining": {"type":["number","null"],"description":"合同剩余年数"},
    "agreementExpiryYear": {"type":["number","null"],"description":"合同到期年份"},
    "officeHoursRequired": {"type":["string","null"],"description":"如 '9am-5pm Mon-Fri', '24/7', 'After Hours Only'"},
    "managerResidenceRequired": {"type":["boolean","null"],"description":"是否要求在物业内居住"},
    "askingPrice": {"type":["number","null"]},
    "priceNote": {"type":["string","null"],"description":"价格说明（如招标、含GST等）"},
    "totalUnits": {"type":["number","null"],"description":"总单元数"},
    "lettingPoolUnits": {"type":["number","null"],"description":"Letting Pool内单元数"},
    "lettingPoolPercent": {"type":["number","null"],"description":"Pool占比，自动计算"},
    "lettingCommissionRate": {"type":["string","null"],"description":"如 '8.5%'"},
    "netIncome": {"type":["number","null"],"description":"年净收入（官方披露）"},
    "netIncomeSource": {"type":"string","enum":["broker","listing","financials","estimated","unknown"],"description":"净收入来源"},
    "estimatedNetIncome": {"type":["number","null"],"description":"估算净收入（仅适用rumour场景）"},
    "estimatedNetIncomeNote": {"type":["string","null"],"description":"估算依据"},
    "multiplier": {"type":["number","null"],"description":"askingPrice / netIncome（若netIncome存在）"},
    "estimatedMultiplier": {"type":["number","null"],"description":"若使用estimatedNetIncome，此处为估算倍数"},
    "bcSalary": {"type":["number","null"],"description":"BC薪资（含/不含GST需注明）"},
    "bcSalaryIncludesGST": {"type":["boolean","null"]},
    "bcSalaryPercent": {"type":["number","null"],"description":"bcSalary / netIncome * 100（自动计算）"},
    "bcSalaryEscalation": {"type":["string","null"],"description":"如 'CPI', '3% p.a.', 'Fixed'"},
    "lettingIncomeAnnual": {"type":["number","null"],"description":"netIncome - bcSalary（自动计算）"},
    "weeklyLettingIncomePerUnit": {"type":["number","null"],"description":"lettingIncomeAnnual / lettingPoolUnits / 52"},
    "operatingExpenses": {"type":["number","null"],"description":"运营支出（ABC, cleaning, utilities等）"},
    "debtServiceEstimate": {"type":["number","null"],"description":"贷款还款估算（基于LVR 70%, 利率6%）"},
    "cashFlowAfterDebt": {"type":["number","null"],"description":"净收入 - debtServiceEstimate"},
    "estimatedNetYield": {"type":["number","null"],"description":"cashFlowAfterDebt / askingPrice * 100%"},
    "propertyPurchaseRequired": {"type":["boolean","null"],"description":"是否需要购买房产"},
    "onSiteRequired": {"type":["boolean","null"],"description":"是否要求现场办公"},
    "key Risks": {"type":"array","items":{"type":"string"},"description":"已识别的风险清单（从hardFailReasons进一步展开）"},
    "assumptions": {"type":"array","items":{"type":"string"},"description":"所有推断假设（如'假设letting commission为8%'）"},
    "scores": {
      "type":"object",
      "properties":{
        "incomeStability":{"type":"number","minimum":0,"maximum":5,"description":"收入稳定性：BC薪资占比、合同年限"},
        "growthPotential":{"type":"number","minimum":0,"maximum":5,"description":"增长潜力：Pool占比、外部单元、租金增长空间"},
        "contractSecurity":{"type":"number","minimum":0,"maximum":5,"description":"合同安全：剩余年限、续约条款"},
        "dataCompleteness":{"type":"number","minimum":0,"maximum":5,"description":"数据完整度：关键字段缺失情况"},
        "operationalSimplicity":{"type":"number","minimum":0,"maximum":5,"description":"运营简便性：设施管理复杂度、onSite要求"}
      },
      "required":["incomeStability","growthPotential","contractSecurity","dataCompleteness","operationalSimplicity"]
    },
    "scoreFormula": {"type":"string","description":"总分计算公式，如: (incomeStability*0.25 + growth*0.25 + contract*0.2 + data*0.15 + ops*0.15)"},
    "ratingScore": {"type":"number","minimum":0,"maximum":5,"description":"综合评分（各子评分加权）"},
    "ratingBasis": {"type":"string","description":"总结性评分解释"},
    "dataGaps": {"type":"array","items":{"type":"string"}},
    "nextAction": {
      "type":"object",
      "properties":{
        "actionType":{"type":"string","enum":["request_docs","contact_broker","schedule_viewing","await_info","can_proceed"],"description":"任务类型"},
        "requiredDocs":{"type":"array","items":{"type":"string"},"description":"需获取的文件：['3年财报','合同摘要','Body Corporate rules']"},
        "contactPerson":{"type":"string","description":"对接人/经纪公司"},
        "contactMethod":{"type":"string","enum":["email","phone","portal","in-person"]},
        "deadline":{"type":"string","format":"date","description":"最后期限"},
        "priority":{"type":"string","enum":["critical","high","medium","low"],"description":"任务优先级"},
        "blockingIssues":{"type":"array","items":{"type":"string"},"description":"当前阻塞问题"},
        "automationPotential":{"type":"string","enum":["manual","templated","auto-track","no-action"],"description":"自动化可能程度"}
      },
      "required":["actionType","contactPerson","priority"]
    },
    "sourceUrl": {"type":"string"},
    "sourceEvidence": {
      "type":"array",
      "items":{
        "type":"object",
        "properties":{
          "fieldName":{"type":"string","description":"引用的数据字段名"},
          "sourceType":{"type":"string","enum":["broker_email","listing_page","body_corporate","financial_statement","assumption","rumour"]},
          "sourceDate":{"type":"string","format":"date"},
          "sourceUrl":{"type":"string"},
          "quoteSnippet":{"type":"string","description":"原文摘录"}
        },
        "required":["fieldName","sourceType"]
      }
    },
    "lastVerifiedDate": {"type":"string","format":"date"},
    "needsRefreshAfterDays": {"type":"number","description":"数据过期天数建议（如90）"},
    "auditTrail": {
      "type":"array",
      "items":{
        "type":"object",
        "properties":{
          "timestamp":{"type":"string","format":"date-time"},
          "action":{"type":"string","description":"如'created','updated','verified','downgraded'"},
          "details":{"type":"string"},
          "agent":{"type":"string","description":"执行者标识"}
        }
      }
    }
  }
}
